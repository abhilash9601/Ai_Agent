    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst seen = new Set();\nconst result = [];\n\nfor (const item of items) {\n  const text = item.json.pageContent || item.json.text || \"\";\n\n  if (!seen.has(text)) {\n    seen.add(text);\n    result.push(item);\n  }\n}\n\nreturn result;"
      },
