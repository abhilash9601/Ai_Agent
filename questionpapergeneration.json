    {
      "parameters": {
        "jsCode": "try {\n  let text = $input.first().json.text || '';\n  const start = text.indexOf('{');\n  const end = text.lastIndexOf('}');\n  if (start !== -1 && end !== -1) {\n    text = text.substring(start, end + 1);\n  }\n  \n  const parsed = JSON.parse(text);\n  const queries = parsed.queries || parsed.questions || [];\n  \n  if (queries.length === 0) throw new Error('No queries found');\n  \n  return queries.map(q => ({\n    json: {\n      query: typeof q === 'string' ? q : (q.questionText || q.question || JSON.stringify(q))\n    }\n  }));\n} catch (e) {\n  // Fallback to the original prompt if AI fails\n  return [{ json: { query: $('Webhook').first().json.body.prompt } }];\n}"
      },
