    {
      "parameters": {
        "jsCode": "try {\n  let text = $input.first().json.text;\n  if (text.indexOf('```') !== -1) {\n    text = text.replace(/```json\\n/g, '').replace(/```/g, '').trim();\n  }\n  const data = JSON.parse(text);\n\n  return (data.top_chunks || []).map(chunk => ({\n    json: {\n      text: chunk.text\n    }\n  }));\n} catch (e) {\n  // Fallback: extract pageContent from original aggregated data\n  const aggregated = $('Aggregate').first().json.data || [];\n  return aggregated.map(i => ({ json: { text: i.pageContent || i.text || \"\" } }));\n}"
      },
      "id": "149df2bd-eab9-4f4c-b781-de19c60bf146",
      "name": "Parse Reranked",
