    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a search query optimizer.\n\nConvert this teacher request into 5 short, distinct search keywords for a syllabus database.\n\nTeacher Request:\n{{$json.body.prompt}}\n\nOutput ONLY valid JSON in this format:\n{\n  \"queries\": [\n    \"topic 1\",\n    \"topic 2\",\n    \"topic 3\",\n    \"topic 4\",\n    \"topic 5\"\n  ]\n}",
        "batching": {}
      },
      "id": "002fca42-5164-4155-a73f-0e1094b4dfaf",
      "name": "Expand Queries via Ollama",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -560,
        544
      ]
    },
    {
      "parameters": {
        "model": "phi3:mini",
        "options": {}
      },
      "id": "8801c64e-e9d7-4eef-a366-c8bd3dc25649",
      "name": "Ollama Chat Model2",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        -560,
        768
      ],
