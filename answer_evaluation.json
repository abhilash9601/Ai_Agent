            "typeVersion": 2.2,
            "position": [
                528,
                400
            ]
        },
        {
            "parameters": {
                "mode": "raw",
                "jsonOutput": "={{ { \"answer_id\": $json.answer_id, \"question_id\": $json.question_id, \"question_type\": \"mcq\", \"score\": ($json.answer_text.trim().toLowerCase() === $json.model_answer.trim().toLowerCase() ? 1 : 0), \"max_score\": 1, \"feedback\": ($json.answer_text.trim().toLowerCase() === $json.model_answer.trim().toLowerCase() ? \"Correct answer.\" : \"Incorrect. Correct answer: \" + $json.model_answer), \"submission_id\": $(\"Evaluate Submission Webhook\").item.json.body.submission_id } }}",
                "options": {}
            },
            "id": "45819f76-41d9-49f7-82fd-7bd53bbca315",
            "name": "Score MCQ Answer",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                784,
                208
            ]
        },
        {
            "parameters": {},
            "id": "c451bc92-9ff4-4713-b70a-74c600441d3a",
            "name": "Merge All Scores",
            "type": "n8n-nodes-base.merge",
            "typeVersion": 3.2,
            "position": [
                1568,
                400
            ]
        },
        {
            "parameters": {
                "mode": "raw",
                "jsonOutput": "={{ { \"answer_id\": $json.answer_id, \"question_id\": $json.question_id, \"submission_id\": $(\"Evaluate Submission Webhook\").item.json.body.submission_id, \"question_type\": \"descriptive\", \"eval_prompt\": \"You are a fair exam evaluator. Score the student answer based ONLY on the provided context and model answer.\\n\\nQUESTION:\\n\" + $json.question_text + \"\\n\\nREFERENCE CONTEXT (from syllabus):\\n\" + $json.context_used + \"\\n\\nMODEL ANSWER:\\n\" + $json.model_answer + \"\\n\\nSTUDENT ANSWER:\\n\" + $json.answer_text + \"\\n\\nEvaluate on: Relevance (0-3), Coverage (0-3), Concept Clarity (0-4). Total = 10.\\nReturn ONLY valid JSON: { \\\"score\\\": 7, \\\"max_score\\\": 10, \\\"relevance\\\": 3, \\\"coverage\\\": 2, \\\"clarity\\\": 2, \\\"feedback\\\": \\\"Detailed feedback here...\\\" }\" } }}",
                "options": {}
            },
            "id": "3d049a31-838b-4e3d-94aa-1296137cac20",
            "name": "Build Evaluation Prompt",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                784,
                608
            ]
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "={{ $json.eval_prompt }}",
                "batching": {}
            },
            "id": "edf18047-c968-4004-8aeb-9778d04629cc",
            "name": "Evaluate Answer with Phi-3",
            "type": "@n8n/n8n-nodes-langchain.chainLlm",
            "typeVersion": 1.9,
            "position": [
                1040,
                608
            ]
        },
        {
            "parameters": {
                "model": "phi3:mini",
                "options": {
                    "temperature": 0.1,
                    "numCtx": 4096,
                    "format": "json"
                }
            },
            "id": "f54b9b72-31d4-4c76-9941-dc6a7bd6e4a7",
            "name": "Ollama Phi-3 (Evaluator)",
            "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
            "typeVersion": 1,
            "position": [
                1040,
                832
            ]
        },
        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "const raw = item.json.text || '';\nlet eval_result;\ntry {\n  const clean = raw.replace(/```json|```/g, '').trim();\n  eval_result = JSON.parse(clean);\n} catch(e) {\n  eval_result = { score: 0, max_score: 10, feedback: 'Evaluation parsing failed.' };\n}\nreturn { json: { answer_id: item.json.answer_id, question_id: item.json.question_id, question_type: 'descriptive', score: eval_result.score || 0, max_score: eval_result.max_score || 10, feedback: eval_result.feedback || '', submission_id: item.json.submission_id } };"
            },
            "id": "e2204090-4d4c-443a-9309-43f7f8812e4e",
            "name": "Parse Evaluation Result",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1312,
                608
            ]
        },
        {
            "parameters": {
                "aggregate": "aggregateAllItemData",
                "destinationFieldName": "evaluations",
                "options": {}
            },
            "id": "00f76160-e466-4053-ab76-9bca23026396",
            "name": "Aggregate All Scores",
            "type": "n8n-nodes-base.aggregate",
            "typeVersion": 1,
            "position": [
                1824,
                400
            ]
        },
        {
            "parameters": {
                "jsCode": "const evals = items[0].json.evaluations || [];\nconst submission_id = evals[0]?.submission_id || '';\nconst total_score = evals.reduce((s, e) => s + (e.score || 0), 0);\nconst max_possible = evals.reduce((s, e) => s + (e.max_score || 0), 0);\nconst percentage = max_possible > 0 ? Math.round((total_score / max_possible) * 100) : 0;\nconst passed = percentage >= 50;\nreturn [{ json: { submission_id, total_score, max_possible, percentage, passed, evaluations: evals } }];"
            },
            "id": "9e15e7db-4f4a-4a3c-874e-ea1479ccbdb9",
            "name": "Calculate Final Score",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2080,
                400
            ],
            "executeOnce": true
        },
        {
            "parameters": {
                "jsCode": "const evals = items[0].json.evaluations || [];\nreturn evals.map(e => ({ json: { answer_id: e.answer_id, question_id: e.question_id, score: e.score, max_score: e.max_score, feedback: e.feedback, submission_id: e.submission_id } }));"
            },
            "id": "9c62f577-bef3-4fc2-a28c-f74f5461fa6f",
            "name": "Store Per-Answer Evaluations",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2352,
                304
            ]
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "INSERT INTO evaluations (submission_id, question_id, answer_id, score, max_score, feedback, evaluated_at) VALUES ($1, $2, $3, $4, $5, $6, NOW())",
                "options": {
                    "queryReplacement": "={{ [$json.submission_id, $json.question_id, $json.answer_id, $json.score, $json.max_score, $json.feedback] }}"
                }
            },
            "id": "c7cb2b39-3a34-49a7-ad3f-ca943afda4da",
            "name": "Insert Evaluations to DB",
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.6,
            "position": [
                2608,
                304
            ]
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "INSERT INTO exam_results (submission_id, total_score, max_possible, percentage, passed, evaluated_at) VALUES ($1, $2, $3, $4, $5, NOW()) ON CONFLICT (submission_id) DO UPDATE SET total_score=$2, max_possible=$3, percentage=$4, passed=$5, evaluated_at=NOW()",
                "options": {
                    "queryReplacement": "={{ [$(\"Calculate Final Score\").item.json.submission_id, $(\"Calculate Final Score\").item.json.total_score, $(\"Calculate Final Score\").item.json.max_possible, $(\"Calculate Final Score\").item.json.percentage, $(\"Calculate Final Score\").item.json.passed] }}"
                }
            },
            "id": "37288e7a-08c0-410f-acdd-77646202f401",
            "name": "Store Final Result",
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.6,
            "position": [
                2864,
                400
            ]
        },
        {
            "parameters": {
                "mode": "raw",
                "jsonOutput": "={{ { \"success\": true, \"submission_id\": $(\"Calculate Final Score\").item.json.submission_id, \"total_score\": $(\"Calculate Final Score\").item.json.total_score, \"max_possible\": $(\"Calculate Final Score\").item.json.max_possible, \"percentage\": $(\"Calculate Final Score\").item.json.percentage, \"passed\": $(\"Calculate Final Score\").item.json.passed } }}",
                "options": {}
            },
