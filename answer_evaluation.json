            ],
            "webhookId": "432c9a3a-e3d9-41f2-ac44-c2bd720aad7b"
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "SELECT sa.id as answer_id, sa.question_id, sa.answer_text, q.question_text, q.question_type, q.context_used, q.model_answer, q.difficulty FROM student_answers sa JOIN questions q ON sa.question_id = q.id WHERE sa.submission_id = $1",
                "options": {
                    "queryReplacement": "={{ $json.body.submission_id }}"
                }
            },
            "id": "55365e42-ec1f-41ce-b244-79db73aec215",
            "name": "Fetch Student Answers",
            "type": "n8n-nodes-base.postgres",
            "typeVersion": 2.6,
            "position": [
                272,
                400
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "combinator": "and",
                    "conditions": [
                        {
                            "leftValue": "={{ $json.question_type }}",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            },
                            "rightValue": "mcq"
                        }
                    ],
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict",
                        "version": 1
                    }
